# Google Sheets API
# Criar API Key em https://console.cloud.google.com > APIs & Services > Credentials
# Habilitar Google Sheets API no projeto
GOOGLE_SHEET_ID=seu_sheet_id_aqui
GOOGLE_SHEETS_API_KEY=sua_api_key_aqui

# (Opcional) URL da API para desenvolvimento local
# Em produção na Vercel, o frontend chama /api/sheets automaticamente
# VITE_API_URL=http://localhost:3000/api/sheets
